PORT=3000
TWENTY_BASE_URL=https://crm.ipsg.com.au
TWENTY_API_TOKEN=
LOGTO_WEBHOOK_SIGNING_KEY=

# Phase 7 — taxonomy sync (Twenty -> Payload, meridian-insights-website)
PAYLOAD_BASE_URL=https://meridian-insights.com
PAYLOAD_API_KEY=
SYNC_TRIGGER_TOKEN=

# Phase 8a — subscriber push (Logto -> Twenty), writes crm_person_id back to
# Logto. Reuses the "crm-sync" M2M application created during Phase 7 for
# this exact purpose (Management API, "all" scope on the resource below).
LOGTO_ENDPOINT=https://auth.ipsg.com.au
LOGTO_M2M_APP_ID=
LOGTO_M2M_APP_SECRET=
LOGTO_MANAGEMENT_API_RESOURCE=https://default.logto.app/api

# Phase 9 — engagement scoring (PostHog -> Twenty) and Enterprise
# lead-capture task creation. Weight/threshold vars all have sane defaults
# in lib/engagementConfig.ts - only set them here to override.
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=
MARK_WORKSPACE_MEMBER_ID=395f078f-a093-4b33-a908-3f13dde620d4
# ENGAGEMENT_LOOKBACK_DAYS=30
# WEIGHT_TENDER_VIEW=10
# WEIGHT_EVENT_VIEW=10
# WEIGHT_ASSESSMENT_READ=5
# WEIGHT_TOPIC_CONCENTRATION=2
# CONCENTRATION_MIN_TOUCHES=3
# ENGAGEMENT_HIGH_THRESHOLD=40
# ENGAGEMENT_TASK_PREFIX=[Engagement]
# lead-capture reuses SYNC_TRIGGER_TOKEN above, no separate secret
